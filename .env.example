# Copy to .env and fill values (do NOT commit .env)

# ============================================
# AI Provider Configuration
# ============================================

# OpenAI API (for cloud-based deployment)
OPENAI_API_KEY=sk-...

# Optional - for web search
SERPAPI_API_KEY=your-serpapi-key-if-you-want-search

# Ollama (for local deployment)
OLLAMA_MODEL=qwen2:7b

# ============================================
# Monitoring and Health Checks
# ============================================

# Health check server port
HEALTH_PORT=8080

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================
# Alerting Configuration
# ============================================

# Slack Integration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# PagerDuty Integration
PAGERDUTY_SERVICE_KEY=your-pagerduty-service-key

# Email Alerting
ALERT_EMAIL_TO=alerts@example.com
ALERT_EMAIL_FROM=noreply@example.com
CRITICAL_ALERT_EMAIL=critical-alerts@example.com
SECURITY_TEAM_EMAIL=security@example.com
COMPLIANCE_TEAM_EMAIL=compliance@example.com

# SMTP Configuration
SMTP_SMARTHOST=smtp.gmail.com:587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ============================================
# Security and Compliance
# ============================================

# Enable forensic mode (enhanced logging, read-only)
FORENSIC_MODE=false

# Data retention period (days)
LOG_RETENTION_DAYS=31
METRICS_RETENTION_DAYS=30

# ============================================
# Optional: Advanced Configuration
# ============================================

# Python settings
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
