# Copy to .env and fill values (do NOT commit .env)
OPENAI_API_KEY=sk-...
# Optional - for web search
SERPAPI_API_KEY=your-serpapi-key-if-you-want-search
# Optional - protect API calls
API_AUTH_TOKEN=super-secret-token
# Observability
LOG_LEVEL=INFO
METRICS_PORT=9000
AUDIT_LOG_PATH=/var/log/agent/audit.log
