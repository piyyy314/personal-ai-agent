# Copy to .env and fill values (do NOT commit .env)

# ============================================
# AI Provider Configuration
# ============================================

# OpenAI API (for cloud-based deployment)
OPENAI_API_KEY=sk-...

# Optional - for web search
SERPAPI_API_KEY=your-serpapi-key-if-you-want-search

# Ollama (for local deployment)
OLLAMA_MODEL=qwen2:7b

# ============================================
# API Authentication
# ============================================

# Set to protect API calls; leave unset only if you also set AUTH_DISABLED=true
API_AUTH_TOKEN=super-secret-token

# Set AUTH_DISABLED=true ONLY for local/dev environments to skip auth
# AUTH_DISABLED=true

# ============================================
# Monitoring and Health Checks
# ============================================

# Health check server port
HEALTH_PORT=8080

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Standalone Prometheus metrics server port (CLI mode only; API mode uses /metrics endpoint)
METRICS_PORT=9000

# Path for audit log file (optional; logs to stdout if unset)
AUDIT_LOG_PATH=/var/log/agent/audit.log

# ============================================
# Performance and Privacy Tuning
# ============================================

# Limit in-memory conversation history for long-running sessions
AGENT_MEMORY_WINDOW=6

# Bounded, privacy-aware response cache settings
AGENT_CACHE_MAX_ENTRIES=128
AGENT_CACHE_TTL_SECONDS=300

# ============================================
# Alerting Configuration
# ============================================

# Slack Integration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# PagerDuty Integration
PAGERDUTY_SERVICE_KEY=your-pagerduty-service-key

# Email Alerting
ALERT_EMAIL_TO=alerts@example.com
ALERT_EMAIL_FROM=noreply@example.com
CRITICAL_ALERT_EMAIL=critical-alerts@example.com
SECURITY_TEAM_EMAIL=security@example.com
COMPLIANCE_TEAM_EMAIL=compliance@example.com

# SMTP Configuration
SMTP_SMARTHOST=smtp.gmail.com:587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# AlertManager receiver config (used by deploy/monitoring/alertmanager.yml)
ALERT_EMAIL=alerts@example.com
ALERT_SMTP_HOST=smtp.gmail.com:587
ALERT_SMTP_USERNAME=your-email@gmail.com
ALERT_SMTP_PASSWORD=your-app-password
ALERT_WEBHOOK_URL=http://alert-webhook-handler:5001/alerts

# Grafana
GRAFANA_ADMIN_PASSWORD=changeme

# ============================================
# Security and Compliance
# ============================================

# Enable forensic mode (enhanced logging, read-only)
FORENSIC_MODE=false

# Data retention period (days)
LOG_RETENTION_DAYS=31
METRICS_RETENTION_DAYS=30

# ============================================
# Optional: Advanced Configuration
# ============================================

# Python settings
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
